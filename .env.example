# Gemini API (required for gemini embedding provider)
GEMINI_API_KEY=

# DashScope / Bailian API (required for dashscope embedding provider)
DASHSCOPE_API_KEY=

# OpenAI-compatible embedding provider (SiliconFlow / Zhipu-GLM / Ollama / vLLM / custom).
# ZotPilot-specific vars take precedence; the generic OPENAI_* vars are the fallback.
ZOTPILOT_EMBEDDING_API_KEY=
ZOTPILOT_EMBEDDING_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# OpenAlex (optional, for faster rate limits on citation lookups)
OPENALEX_EMAIL=

# Anthropic API (optional, for vision-based table extraction)
ANTHROPIC_API_KEY=

# Zotero Web API (optional, for write operations: tagging, collections)
ZOTERO_API_KEY=
ZOTERO_USER_ID=
