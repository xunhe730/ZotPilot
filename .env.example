# Gemini API (required for gemini embedding provider)
GEMINI_API_KEY=

# Custom Gemini base URL (optional; for API proxies / restricted regions)
# Leave blank to use the official Google endpoint.
GEMINI_BASE_URL=

# OpenAlex (optional, for faster rate limits on citation lookups)
OPENALEX_EMAIL=

# Anthropic API (optional, for vision-based table extraction)
ANTHROPIC_API_KEY=

# Zotero Web API (optional, for write operations: tagging, collections)
ZOTERO_API_KEY=
ZOTERO_USER_ID=
